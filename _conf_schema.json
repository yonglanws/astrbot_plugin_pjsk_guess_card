{
  "answer_timeout": {
    "description": "猜卡游戏的答题时长（秒）",
    "type": "int",
    "default": 30,
    "hint": "设置玩家回答问题的超时时间，单位为秒。"
  },
  "daily_play_limit": {
    "description": "每位玩家每日可参与猜卡的次数上限（-1表示无限制）",
    "type": "int",
    "default": 10,
    "hint": "设置每个用户每天可以玩几次猜卡游戏。设置为-1表示无限制。"
  },
  "super_users": {
    "description": "管理员用户ID列表",
    "type": "list",
    "items": {
      "type": "string"
    },
    "default": [],
    "hint": "在此处添加管理员的QQ号（字符串形式），他们将有权限使用特殊指令，例如重置用户游戏次数。"
  },
  "blacklist": {
    "description": "黑名单用户ID列表",
    "type": "list",
    "items": {
      "type": "string"
    },
    "default": [],
    "hint": "在此处添加被拉黑用户的QQ号（字符串形式），这些用户将无法使用猜卡功能。"
  },
  "group_whitelist": {
    "description": "群聊白名单",
    "type": "list",
    "items": {
      "type": "string"
    },
    "default": [],
    "hint": "在此处添加允许使用此插件的群聊ID。如果列表为空，则所有群聊都允许使用。"
  },
  "whitelist_reject_message": {
    "description": "非白名单群聊的提示文本",
    "type": "string",
    "default": "⚠️ 抱歉，当前群聊未在白名单中，无法使用此功能。如需使用，请联系管理员将本群添加到白名单。",
    "hint": "当非白名单群聊的用户尝试触发游戏时，向其显示的提示信息。留空则不提示。"
  },
  "game_cooldown_seconds": {
    "description": "游戏冷却时间（秒）。",
    "type": "int",
    "default": 60
  },
  "max_guess_attempts": {
    "type": "int",
    "description": "每轮猜卡的最大尝试次数（-1表示无限制）",
    "default": 10,
    "hint": "设置每轮游戏中，所有玩家总共可以尝试回答的次数上限。设置为-1表示无限制。"
  },
  "remote_resource_url_base": {
    "description": "远程资源服务器的根 URL",
    "type": "string",
    "default": "http://47.110.56.9",
    "hint": "当'使用本地资源'为 false 时, 插件将从此 URL 下载资源。URL末尾不需要加'/'。例如: https://example.com/sekai_card_assets"
  },
  "use_local_resources": {
    "description": "是否使用本地资源",
    "type": "bool",
    "default": false,
    "hint": "如果为 true, 插件将从本地 resources 文件夹加载图片。如果为 false, 将从下方配置的 URL 加载。"
  },
  "ranking_display_count": {
    "description": "排行榜显示的人数",
    "type": "int",
    "default": 10,
    "hint": "设置排行榜要显示的玩家数量，建议范围：5-20"
  },
  "effects": {
