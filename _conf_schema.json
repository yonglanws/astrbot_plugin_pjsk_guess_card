  "reward_valid_time": {
    "description": "奖励有效时间（秒）",
    "type": "int",
    "default": 0,
    "hint": "第一个玩家答对后，其他玩家在此时间内答对也能获得分数。设置为0表示禁用此功能（只有第一个答对者得分），设置为大于0的值表示启用功能并设定有效时间（单位：秒）。建议范围：3-15秒"
  }
