            "hint": "控制分块的大小，值越大区块越少"
          }
        }
      },
      "shuffle_blocks_hard": {
        "description": "分块打乱(困难)效果配置",
        "type": "object",
        "default": {},
        "items": {
          "enabled": {
            "type": "bool", 
            "default": true,
            "description": "是否启用",
            "hint": "勾选此项以启用分块打乱(困难)效果"
          },
          "difficulty": {
            "type": "int", 
            "default": 4,
            "description": "分数",
            "hint": "控制猜对时获得的分数"
          },
          "block_size": {
            "type": "int", 
            "default": 20,
            "description": "区块大小",
            "hint": "控制分块的大小，值越大区块越少"
          }
        }
      },
      "glitch": {
        "description": "损坏效果配置",
        "type": "object",
        "default": {},
        "items": {
          "enabled": {
            "type": "bool", 
            "default": true,
            "description": "是否启用",
            "hint": "勾选此项以启用损坏效果"
          },
          "difficulty": {
            "type": "int", 
            "default": 3,
            "description": "分数",
            "hint": "控制猜对时获得的分数"
          },
          "glitch_intensity": {
            "type": "int", 
            "default": 1,
            "description": "损坏强度",
            "hint": "控制损坏效果的强度，值越大损坏越剧烈"
          }
        }
      }
    }
  }
} 